# Justice Gavel — Root .env.example
# Copy to .env and fill in values

# ── Backend (backend/.env) ─────────────────────────────────────────────────────
# Required: set in Railway Environment Variables
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_32_BYTES_HEX
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX
ADMIN_KEY=CHANGE_ME_RANDOM_24_CHARS
STRIPE_SECRET=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME
TWILIO_ACCOUNT_SID=ACCHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1CHANGE_ME
SENDGRID_API_KEY=SG.CHANGE_ME
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
CORS_ORIGIN=https://app.justicegavel.com
NODE_ENV=development
PORT=4000

# ── Optional (defaults shown) ─────────────────────────────────────────────────
# POSTGRES_URL=postgresql://user:pass@host:5432/dbname
# LOG_LEVEL=info
# LOG_FORMAT=json
# EXPO_ACCESS_TOKEN=your-expo-token

# ── Frontend (frontend/.env) ───────────────────────────────────────────────────
EXPO_PUBLIC_API_BASE=http://localhost:4000/api
EXPO_PUBLIC_SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
EXPO_PUBLIC_MIXPANEL_TOKEN=CHANGE_ME
