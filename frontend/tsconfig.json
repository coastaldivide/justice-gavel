{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "strictFunctionTypes": false,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "allowJs": true,
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "react",
      "react-native"
    ],
    "lib": [
      "ESNext"
    ]
  },
  "exclude": [
    "e2e/**/*",
    "e2e"
  ]
}