# ────────────────────────────────────────────────────────────────
# Justice Gavel — Frontend Environment Variables
# Copy this file to .env and fill in your values before building.
#
# IMPORTANT: Never commit .env to version control.
#            .env is already in .gitignore.
# ────────────────────────────────────────────────────────────────

# ── Backend API URL ─────────────────────────────────────────────
# The base URL of your deployed backend, including /api
# Development:  http://localhost:4000/api
# Production:   https://your-backend.railway.app/api
#
# This variable is REQUIRED. Without it, all API calls on a real
# device will hit localhost:4000 and fail silently.
EXPO_PUBLIC_API_BASE=https://your-backend.railway.app/api

# ── Sentry Crash Reporting ──────────────────────────────────────
# Get your DSN from https://sentry.io → Project → Settings → Client Keys
# Leave empty to disable crash reporting (not recommended for production).
EXPO_PUBLIC_SENTRY_DSN=

# ── Stripe Publishable Key ──────────────────────────────────────
# The PUBLISHABLE (not secret) key from your Stripe dashboard.
# Starts with pk_live_ (production) or pk_test_ (testing).
# Dashboard: https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# ── Environment flag ────────────────────────────────────────────
# Set to 'production' before building for the App Store / Play Store.
# Controls Sentry activation, analytics, and feature flags.
EXPO_PUBLIC_ENV=development

# ── EAS Project ID ──────────────────────────────────────────────
# Your Expo Application Services project ID.
# Get from: https://expo.dev → Your project → Settings
# Also update app.json → expo.updates.url and expo.extra.eas.projectId
EXPO_PUBLIC_EAS_PROJECT_ID=REPLACE_WITH_EAS_PROJECT_ID

# ── Google Places API Key (optional) ───────────────────────────
# Enables address autocomplete in attorney and courthouse search.
# Get from: https://console.cloud.google.com → APIs → Places API
# Leave empty to use GPS-only search (app works without this).
EXPO_PUBLIC_GOOGLE_PLACES_KEY=
