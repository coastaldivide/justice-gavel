        "NSFaceIDUsageDescription": "Justice Gavel uses Face ID to protect your sensitive legal information.",
        "NSMicrophoneUsageDescription": "Justice Gavel uses your microphone to record voice notes that are transcribed into text for your case.",
        "NSLocationWhenInUseUsageDescription": "Justice Gavel uses your location to find nearby attorneys, bail bondsmen, and court facilities.",
        "NSContactsUsageDescription": "Justice Gavel accesses your contacts to let you add emergency contacts for the SOS feature.",
        "NSPhotoLibraryAddUsageDescription": "Justice Gavel saves documents to your photo library.",
        "NSSpeechRecognitionUsageDescription": "Justice Gavel uses speech recognition to transcribe your voice notes.",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "location"
