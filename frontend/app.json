      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      },
      "reviewNotes": "Reviewer credentials: see App Store Connect > App Review Notes. Subscription purchase on iOS opens the web browser to justicegavel.app/subscribe \u2014 this is the intended behavior per Apple guideline \u00a73.1.1 compliance while native StoreKit integration is in development. All other features are fully functional."
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#042C53"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.justicegavel.mobile",
      "buildNumber": "5.89.17",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Justice Gavel adds your court dates to your calendar so you never miss a hearing.",
