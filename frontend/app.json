    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#042C53"
      },
      "package": "app.justicegavel.mobile",
      "versionCode": 5997,
      "permissions": [
        "READ_MEDIA_IMAGES",
        "CAMERA",
        "USE_BIOMETRIC",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "justicegavel.app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "privacyPolicyUrl": "https://justicegavel.app/privacy",
      "jsEngine": "hermes",
      "targetSdkVersion": 34,
      "minSdkVersion": 24,
      "googleServicesFile": "./google-services.json"
    },
    "backgroundColor": "#020E1C",
    "scheme": "justicegavel",
    "privacyPolicyUrl": "https://justicegavel.app/privacy",
    "termsOfServiceUrl": "https://justicegavel.app/terms",
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Justice Gavel uses the camera to scan charging documents and bail slips."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#042C53",
          "sounds": []
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Justice Gavel uses Face ID to protect your sensitive legal information."
        }
      ]
    ],
    "description": "Legal help for people who need it most. Find bail agents, connect with lawyers, know your rights, and get AI-powered legal guidance \u2014 all in one place.",
    "metadata": {
      "appleCategoryId": "6013",
      "appleSecondaryCategory": "6012",
      "apple": {
        "subtitle": "Legal help for everyone",
        "promotionalText": "Find lawyers, track court dates, and know your rights \u2014 powered by AI. Built for people who need legal help but can't afford to be lost in the system."
      },
      "google": {
        "shortDescription": "AI legal guide, attorney finder & case tracker"
      }
    },
    "fonts": [
      "./assets/fonts/Inter_400Regular.ttf",
      "./assets/fonts/Inter_500Medium.ttf",
      "./assets/fonts/Inter_600SemiBold.ttf",
      "./assets/fonts/Inter_700Bold.ttf",
      "./assets/fonts/Inter_800ExtraBold.ttf",
      "./assets/fonts/Inter_900Black.ttf"
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/REPLACE_WITH_EAS_PROJECT_ID"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "keywords": [
      "legal help",
      "attorney finder",
      "bail bonds",
      "criminal defense",
      "legal rights",
      "public defender",
      "court dates",
      "expungement",
      "case tracker",
      "legal aid",
      "Miranda rights",
      "justice"
    ],
    "shortDescription": "AI legal help, attorney finder, bail bonds & case tracker \u2014 your rights in one app.",
    "experiments": {
      "newArchEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png",
      "name": "Justice Gavel",
      "shortName": "JusticeGavel",
      "lang": "en",
      "themeColor": "#042C53",
      "backgroundColor": "#042C53",
      "description": "Free legal help if you get arrested. Find attorneys, bail bondsmen, and know your rights.",
      "htmlPath": "./web/index.html"
    },
    "userInterfaceStyle": "automatic",
    "hooks": {
      "postPublish": [
        {
          "file": "sentry-expo/upload-sourcemaps",
          "config": {
            "organization": "justice-gavel",
            "project": "justice-gavel-mobile",
            "authToken": "${SENTRY_AUTH_TOKEN}"
          }
        }
      ]
    },
    "privacyChoicesUrl": "https://justicegavel.app/privacy#choices"
  }
}