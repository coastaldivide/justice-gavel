/**
 * motions.js — AI motion template library
 *
 * POST /api/motions/generate        — generate a motion draft ($9.99)
 * GET  /api/motions/history         — user's previously generated motions
 * GET  /api/motions/history/:id     — single motion
 * DELETE /api/motions/history/:id   — delete from history
 *
 * Pipeline:
 *   1. User selects motion type + fills 6-10 case fields
 *   2. Stripe charges $9.99 (or demo mode returns mock)
 *   3. Claude generates a jurisdiction-aware motion draft
 *   4. Draft saved to motion_history, returned to client
 *   5. Client copies, edits, exports — done
 *
 * Cost per motion: ~$0.02 (Claude prompt + output)
 * Revenue per motion: $9.99
 * Margin: ~$9.97
 */

import { perUserAiLimit } from '../middleware/sharedAiLimiter.js';
import { err400, err401, err403, err404, err409, err422, err500, err502, safeInt, sanitizeStr, validateEmail, normalizeEmail, ownsResource, buildWhere, API_URLS } from '../utils/routeHelpers.js';
import express from 'express';
import { getDb } from '../db/index.js';
import { authRequired } from './auth.js';
import { enqueue } from '../services/aiQueue.js';

// ── AI-specific rate limiter (50 requests / 15 min per IP) ─────────────────
import rateLimit from 'express-rate-limit';
import logger from '../utils/logger.js';
const aiLimiter = rateLimit({
  windowMs: 15 * 60 * 1000,
  max: 50,
  standardHeaders: true,
  legacyHeaders: false,
  message: { error: 'Too many AI requests — please wait before trying again.' },
  keyGenerator: (req) => req.user?.id ? `user_${req.user.id}` : req.ip,
});

const router = express.Router();
const ANTHROPIC_KEY = process.env.ANTHROPIC_API_KEY;
const STRIPE_SECRET  = process.env.STRIPE_SECRET;

