{
  "name": "justicegavel-backend",
  "version": "6.6.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/scripts/migrate.js",
    "seed": "node src/scripts/seed_demo.js",
    "seed:providers": "node src/scripts/seed_providers.js",
    "seed:providers:reset": "node src/scripts/seed_providers.js --reset",
    "refresh:providers": "node src/scripts/refresh.js",
    "refresh:providers:dry": "node src/scripts/refresh.js --dry-run",
    "refresh:providers:city": "node src/scripts/refresh.js --city \"Nashville, TN\"",
    "scrape:bars": "node src/scripts/scrape_state_bars.js --state all",
    "scrape:bars:tn": "node src/scripts/scrape_state_bars.js --state TN",
    "scrape:bars:dry": "node src/scripts/scrape_state_bars.js --state TN --dry-run",
    "scrape:bars:list": "node src/scripts/scrape_state_bars.js --list",
    "scrape:providers:national": "node src/scripts/scrape_providers_national.js",
    "scrape:providers:national:dry": "node src/scripts/scrape_providers_national.js --dry-run",
    "scrape:providers:national:list": "node src/scripts/scrape_providers_national.js --list",
    "scrape:providers:national:state": "node src/scripts/scrape_providers_national.js --state TN",
    "scrape:providers:national:bar": "node src/scripts/scrape_providers_national.js --source bar",
    "scrape:providers:national:google": "node src/scripts/scrape_providers_national.js --source google",
    "scrape:providers:lawyers": "node src/scripts/scrape_providers_national.js --type lawyers",
    "scrape:providers:bail": "node src/scripts/scrape_providers_national.js --type bail",
    "scrape:arrests": "node src/scripts/scrape_arrests.js",
    "scrape:arrests:dry": "node src/scripts/scrape_arrests.js --dry-run",
    "scrape:arrests:list": "node src/scripts/scrape_arrests.js --list",
    "scrape:arrests:national": "node src/scripts/scrape_arrests.js --since 24h",
    "scrape:arrests:state": "node src/scripts/scrape_arrests.js --state TN",
    "scrape:arrests:tier1": "node src/scripts/scrape_arrests.js --tier 1",
    "alerts:send": "node -e \"import('./src/services/arrest_alerts.js').then(m=>m.sendArrestAlerts())\"",
    "import:csv": "node src/scripts/import_csv.js",
    "import:csv:template": "node src/scripts/import_csv.js --template",
    "pipeline:full": "npm run migrate && npm run seed && npm run seed:providers && npm run scrape:arrests:national && npm run alerts:send",
    "pipeline:dry": "npm run scrape:arrests:dry && npm run scrape:providers:national:dry",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --config jest.config.js",
    "test:coverage": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --config jest.config.js --coverage",
    "test:watch": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --config jest.config.js --watch",
    "start:prod": "NODE_ENV=production pm2-runtime start ecosystem.config.cjs --env production",
    "start:pm2": "pm2 start ecosystem.config.cjs --env production",
    "stop": "pm2 stop justice-gavel-api",
    "restart": "pm2 restart justice-gavel-api",
    "logs": "pm2 logs justice-gavel-api",
    "monit": "pm2 monit",
    "db:health": "node --experimental-vm-modules src/scripts/db-health.js",
    "migrate:postgres": "node --experimental-vm-modules src/scripts/migrate_to_postgres.js",
    "predeploy": "node --experimental-vm-modules src/scripts/db-health.js",
    "deploy:check": "npm run predeploy && npm test",
    "i18n:validate": "node --experimental-vm-modules src/scripts/validate-i18n.js",
    "prestart": "node src/db/migrate.js 2>/dev/null || echo \"Migration skipped\""
  },
  "dependencies": {
    "@sentry/node": "7.120.4",
    "@sentry/profiling-node": "10.55.0",
    "@supabase/supabase-js": "2.106.1",
    "bcryptjs": "2.4.3",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "expo-server-sdk": "3.8.0",
    "express": "4.19.2",
    "express-rate-limit": "7.5.1",
    "form-data": "4.0.0",
    "helmet": "7.2.0",
    "hpp": "0.2.3",
    "jsonwebtoken": "9.0.2",
    "knex": "3.1.0",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "node-cron": "4.0.0",
    "node-fetch": "3.3.2",
    "nodemailer": "8.0.10",
    "opossum": "9.0.0",
    "p-queue": "8.0.1",
    "pdfkit": "0.18.0",
    "pg": "8.21.0",
    "response-time": "2.3.2",
    "sql.js": "1.12.0",
    "sqlite": "5.1.1",
    "stripe": "14.25.0",
    "twilio": "5.4.0",
    "unzipper": "0.12.3",
    "yargs": "17.7.2",
    "zod": "4.4.3"
  },
  "description": "Justice Gavel \u2014 Backend API",
  "devDependencies": {
    "better-sqlite3": "12.9.0",
    "jest": "29.7.0",
    "sql.js": "1.14.1",
    "supertest": "7.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "qs": ">=6.14.0",
    "ip-address": ">=10.0.0",
    "uuid": ">=10.0.0",
    "tar": ">=7.5.11",
    "@tootallnate/once": ">=2.0.1",
    "make-fetch-happen": ">=11.0.0"
  },
  "optionalDependencies": {
    "sqlite3": "^5.1.7"
  }
}