# Justice Gavel — Required Environment Variables
# Production deployment checklist (Railway + Supabase)
# All vars marked REQUIRED must be set before launch
# Run: node scripts/check-env.js to validate

# ── CORE ──────────────────────────────────────────────────────────────────────
NODE_ENV=production                          # REQUIRED: 'production'
PORT=4000                                    # REQUIRED: Railway sets this

# ── JWT / AUTH ────────────────────────────────────────────────────────────────
JWT_SECRET=                                  # REQUIRED: min 32 chars random string
JWT_REFRESH_SECRET=                          # REQUIRED: different from JWT_SECRET
JWT_EXPIRES_IN=15m                           # Access token (15 minutes)
JWT_REFRESH_EXPIRES_IN=7d                    # Refresh token (7 days)

# ── DATABASE ──────────────────────────────────────────────────────────────────
SUPABASE_URL=                                # REQUIRED: https://xxx.supabase.co
SUPABASE_ANON_KEY=                           # REQUIRED: public anon key
SUPABASE_SERVICE_KEY=                        # REQUIRED: service role key (keep secret)
DATABASE_URL=                                # REQUIRED: postgres://... connection string

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                           # REQUIRED: sk-ant-... from console.anthropic.com

# ── PAYMENTS ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                           # REQUIRED: sk_live_... (sk_test_ for staging)
STRIPE_WEBHOOK_SECRET=                       # REQUIRED: whsec_... from Stripe dashboard
STRIPE_ADVISOR_PRICE_ID=                     # REQUIRED: price_... 
STRIPE_LEGAL_PRO_PRICE_ID=                   # REQUIRED: price_...
STRIPE_ESQUIRE_PRICE_ID=                     # REQUIRED: price_...
STRIPE_ADVISOR_ANNUAL_ID=                    # REQUIRED: price_...
STRIPE_LEGAL_PRO_ANNUAL_ID=                  # REQUIRED: price_...
STRIPE_ESQUIRE_ANNUAL_ID=                    # REQUIRED: price_...
STRIPE_LEGAL_RADAR_ID=                       # REQUIRED: price_...

# ── COMMUNICATIONS ────────────────────────────────────────────────────────────
SENDGRID_API_KEY=                            # REQUIRED for email: SG....
SENDGRID_FROM_EMAIL=noreply@justicegavel.app # REQUIRED: verified sender
TWILIO_ACCOUNT_SID=                          # Required for SMS: AC...
TWILIO_AUTH_TOKEN=                           # Required for SMS
TWILIO_FROM_NUMBER=                          # Required for SMS: +1...

# ── MONITORING ────────────────────────────────────────────────────────────────
SENTRY_DSN=                                  # REQUIRED: https://xxx@sentry.io/...
SENTRY_ENVIRONMENT=production                # REQUIRED

# ── CORS / DOMAINS ────────────────────────────────────────────────────────────
FRONTEND_URL=https://api.justicegavel.app    # REQUIRED: allowed CORS origin
CORS_ORIGIN=https://api.justicegavel.app     # REQUIRED: comma-separated allowed origins

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
DEMO_MODE=false                              # Set to 'false' for production
LIVE_SMS=true                                # Enable Twilio SMS
LIVE_EMAIL=true                              # Enable SendGrid email
LIVE_PAYMENTS=true                           # Enable Stripe live payments
