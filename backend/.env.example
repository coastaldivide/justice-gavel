# ── Justice Gavel Backend — Environment Variables ────────────────────────────
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# Generate secrets with:  openssl rand -hex 32

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REQUIRED IN PRODUCTION (app refuses to start if any are missing)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Authentication — 32-byte random hex
JWT_SECRET=GENERATE_WITH_openssl_rand_hex_32

# AES-256-GCM encryption for case notes + messages at rest
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_32

# AI — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Payments — get from dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET=sk_live_...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL — features degrade gracefully if absent; warning logged at startup
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Stripe webhook signature verification
STRIPE_WEBHOOK_SECRET=whsec_...

# Error monitoring — get from sentry.io → Settings → Projects → DSN
SENTRY_DSN=https://...@o0.ingest.sentry.io/0

# Database — leave empty for SQLite (dev/staging), set for Postgres (production)
# Format: postgresql://user:password@host:5432/database
POSTGRES_URL=

# Email (SendGrid)
SENDGRID_API_KEY=SG....
SENDGRID_FROM=noreply@justicegavel.app

# SMS (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Google Places (provider search fallback)
GOOGLE_PLACES_KEY=AIza...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# YEAR 3 — INTEGRATION PROVIDER OAUTH2 CREDENTIALS
# Leave blank to run in demo mode (mock responses, no live API calls)
# Register your OAuth app at each provider's developer portal to get credentials.
# Each provider needs:  CLIENT_ID + CLIENT_SECRET
# Redirect URI to register:  https://yourdomain.com/api/integrations/oauth/callback
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# iManage Work — https://docs.imanage.com/api → OAuth Apps
IMANAGE_CLIENT_ID=
IMANAGE_CLIENT_SECRET=

# NetDocuments — https://support.netdocuments.com/api → Developer Portal
NETDOCUMENTS_CLIENT_ID=
NETDOCUMENTS_CLIENT_SECRET=

# Clio Manage — https://app.clio.com/settings/developer_applications
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=

# PracticePanther — https://www.practicepanther.com/api
PRACTICEPANTHER_CLIENT_ID=
PRACTICEPANTHER_CLIENT_SECRET=

# MyCase — https://app.mycase.com/api
MYCASE_CLIENT_ID=
MYCASE_CLIENT_SECRET=

# Google Calendar — https://console.cloud.google.com → OAuth2 credentials
# Scopes needed: https://www.googleapis.com/auth/calendar.events
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Microsoft Outlook/Exchange — https://portal.azure.com → App Registrations
# Scopes needed: Calendars.ReadWrite offline_access
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APP CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NODE_ENV=production
PORT=4000

# Public URL of this backend (used for SAML ACS + OAuth callback redirect URIs)
BASE_URL=https://api.yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# Admin API key for /api/admin/* and /api/bot/* (timing-safe comparison)
ADMIN_KEY=GENERATE_WITH_openssl_rand_hex_32

# Demo mode — set to 'false' in production to enforce required var checks
DEMO_MODE=false

# Feature flags — set to 'true' to enable live integrations
LIVE_PAYMENTS=false
LIVE_EMAIL=false
LIVE_SMS=false
LIVE_REFRESH=false

# Nightly scheduler (node-cron format, defaults to 3 AM)
REFRESH_CRON=0 3 * * *

# Stripe configuration
STRIPE_PRICE_ID=price_XXXXXXXXXXXXXX
STRIPE_SUCCESS_URL=https://yourdomain.com/success
STRIPE_CANCEL_URL=https://yourdomain.com/cancel
STRIPE_ACH_ENABLED=false

# SSO deep-link redirect — where to send users after SAML authentication
APP_SSO_REDIRECT=https://yourdomain.com/auth/sso-callback

# OAuth callback redirect — where to send users after provider OAuth flow
APP_OAUTH_REDIRECT=https://yourdomain.com/settings/integrations

# Outbound bot base URL (for payment links in SMS/email)
BOT_WEBHOOK_BASE_URL=https://yourdomain.com

# Alert emails
ALERT_EMAIL_FROM=alerts@justicegavel.app

# Expo push notifications
EXPO_ACCESS_TOKEN=

# AI queue concurrency (default 8 parallel jobs)
AI_CONCURRENCY=8

# JWT expiry (e.g. 30d, 7d, 1h)
JWT_EXPIRES_IN=30d

# CourtListener / RECAP
COURTLISTENER_ENABLED=true
COURTLISTENER_TOKEN=

# ── Health Scan ────────────────────────────────
# Health scan admin notifications
ADMIN_ALERT_EMAIL=admin@yourfirm.com
ADMIN_ALERT_SMS=+15551234567
HEALTH_SCAN_CRON=0 6,18 * * *
REFRESH_TZ=America/Chicago
SCAN_QUIET=false
SCAN_NOTIFY_INFO=false

# ── Web Push (VAPID) ────────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
# Required for push notifications in the web PWA and Electron desktop app.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@justicegavel.app
